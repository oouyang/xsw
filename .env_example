img=oouyang/xsw
tag=latest
BASE_URL=https://czbooks.net
INDEX_URL=https://your-artifactory.example.com/artifactory/api/pypi/pypi-virtual/simple
TRUSTED_HOST=your-artifactory.example.com
API_BASE_URL=/xsw/api

# Authentication
AUTH_ENABLED=false

# Background job configuration
BG_JOB_WORKERS=2
BG_JOB_RATE_LIMIT=2.0

# Midnight sync configuration
MIDNIGHT_SYNC_HOUR=0
MIDNIGHT_SYNC_MINUTE=0
MIDNIGHT_SYNC_RATE_LIMIT=5.0

# Rate Limiting Configuration
# Progressive delays: 0-50 req/min = no delay, 51-100 = 1s, 101-200 = 10s, 201-500 = 60s, 500+ = 300s
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WHITELIST=127.0.0.1,::1,10.0.0.0/8,192.168.0.0/16


OCTILE_JWT_SECRET=change-me-to-a-random-secret
OCTILE_SMTP_HOST=smtp.gmail.com
OCTILE_SMTP_PORT=587
OCTILE_SMTP_USER=your-email@gmail.com
OCTILE_SMTP_PASSWORD=your-app-password
OCTILE_FROM_EMAIL=noreply@your-domain.com
OCTILE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
OCTILE_GOOGLE_CLIENT_SECRET=your-google-client-secret

HTTP_PROXY_URL=http://your-proxy:port
WORKER_HMAC_SECRET=change-me-to-a-random-hex-string
OCTILE_GOOGLE_REDIRECT_URI=https://your-worker.workers.dev/auth/google/callback
